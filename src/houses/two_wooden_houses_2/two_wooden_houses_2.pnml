// Construction State Switches

    switch(FEAT_HOUSES, SELF, sprlay_two_wooden_houses_2_a_L_1xwater_norm, construction_state) {
        3: sprlay_two_wooden_houses_2_a_L_1xwater_fin_norm;
           sprlay_two_wooden_houses_2_a_L_1xwater_con_norm;
    }
    switch(FEAT_HOUSES, SELF, sprlay_two_wooden_houses_2_a_L_2xwater_norm, construction_state) {
        3: sprlay_two_wooden_houses_2_a_L_2xwater_fin_norm;
           sprlay_two_wooden_houses_2_a_L_2xwater_con_norm;
    }
    switch(FEAT_HOUSES, SELF, sprlay_two_wooden_houses_2_a_L_nowater_norm, construction_state) {
        3: sprlay_two_wooden_houses_2_a_L_nowater_fin_norm;
