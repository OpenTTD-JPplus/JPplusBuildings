// Spritelayouts for two_wooden_houses_2

// A variant | L level | Norm
    spritelayout sprlay_two_wooden_houses_2_a_L_1xwater_con_norm {
        ground {
            sprite:        spr_ground_grass_norm(LOAD_TEMP(2));
        }
        building {
            sprite:        spr_two_wooden_houses_2_a_L_norm (construction_state);
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(1);
        }
        childsprite { // front
            sprite:        spr_two_wooden_houses_2_a_L_front_norm (construction_state); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(19);
        }
        childsprite { // fence
            sprite:        spr_two_wooden_houses_2_a_L_fence_1x (LOAD_TEMP(4)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
        }
    }

