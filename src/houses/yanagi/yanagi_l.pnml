// Ground

        spriteset (spr_yanagi_l_a_ground_norm, "src/houses/yanagi/gfx/ground_norm.png") {template_ground_norm(80,2)}
        spriteset (spr_yanagi_l_a_ground_snow, "src/houses/yanagi/gfx/ground_snow.png") {template_ground_norm(80,2)}
        spriteset (spr_yanagi_l_b_ground_norm, "src/houses/yanagi/gfx/ground_norm.png") {template_ground_norm(80,4)}
