        spriteset (spr_yanagi_l_b_fence_1x, "src/houses/yanagi/gfx/l_fence_b_1x.png") {template_child_norm(80,4)}
        spriteset (spr_yanagi_l_b_fence_2x, "src/houses/yanagi/gfx/l_fence_b_2x.png") {template_child_norm(80,4)}


// Spritelayouts for yanagi_l

// A variant | 7L level | Norm
    spritelayout sprlay_yanagi_l_a_7L_1xwater_norm {
        ground {
            sprite:        spr_yanagi_l_a_ground_norm(LOAD_TEMP(2));
        }
        building {
            sprite:        spr_yanagi_l_a_7L_norm (3);
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(1);
        }
        childsprite { // fence
            sprite:        spr_yanagi_l_a_fence_1x (LOAD_TEMP(4)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
            always_draw:  1;
            hide_sprite:  construction_state != 3;
        }
    }

