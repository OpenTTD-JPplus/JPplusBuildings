        spriteset (spr_yanagi_m_a_5L_snow, "src/houses/yanagi/gfx/snow.png") {template_house_norm(80,1)}
        spriteset (spr_yanagi_m_b_5L_norm, "src/houses/yanagi/gfx/norm.png") {template_house_norm(80,3)}
