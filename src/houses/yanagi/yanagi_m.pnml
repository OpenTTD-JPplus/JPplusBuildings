// Ground

        spriteset (spr_yanagi_m_a_ground_norm, "src/houses/yanagi/gfx/ground_norm.png") {template_ground_norm(80,1)}
        spriteset (spr_yanagi_m_a_ground_snow, "src/houses/yanagi/gfx/ground_snow.png") {template_ground_norm(80,1)}
        spriteset (spr_yanagi_m_b_ground_norm, "src/houses/yanagi/gfx/ground_norm.png") {template_ground_norm(80,3)}
