// Spritelayout Switches
    // a
        // L
            switch (FEAT_HOUSES,SELF, switch_two_wooden_houses_1_a_L_sprites_1xwater, [ 
                STORE_TEMP((current_year - age) < 1959 ? two_wooden_houses_1_build_clr_old() : two_wooden_houses_1_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? two_wooden_houses_1_front_old() : two_wooden_houses_1_front_new(), 19), 
                STORE_TEMP(two_wooden_houses_1_fence_new(), 5), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(GroundSlopes(), 4), 
                STORE_TEMP(Season(), 10),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_two_wooden_houses_1_a_L_1xwater_snow; sprlay_two_wooden_houses_1_a_L_1xwater_norm; } 

            switch (FEAT_HOUSES,SELF, switch_two_wooden_houses_1_a_L_sprites_2xwater, [ 
                STORE_TEMP((current_year - age) < 1959 ? two_wooden_houses_1_build_clr_old() : two_wooden_houses_1_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? two_wooden_houses_1_front_old() : two_wooden_houses_1_front_new(), 19), 
