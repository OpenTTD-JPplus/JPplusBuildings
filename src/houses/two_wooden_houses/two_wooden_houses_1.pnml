                {1: sprlay_two_wooden_houses_1_a_L_nowater_snow; sprlay_two_wooden_houses_1_a_L_nowater_norm; } 

    switch (FEAT_HOUSES, SELF, switch_two_wooden_houses_1_a_L_bywater, RiverDirections() ) {
        0:     switch_two_wooden_houses_1_a_L_sprites_nowater;
        1:     switch_two_wooden_houses_1_a_L_sprites_1xwater;
        2:     switch_two_wooden_houses_1_a_L_sprites_1xwater;
        4:     switch_two_wooden_houses_1_a_L_sprites_1xwater;
        8:     switch_two_wooden_houses_1_a_L_sprites_1xwater;
            switch_two_wooden_houses_1_a_L_sprites_2xwater;
    }

    switch (FEAT_HOUSES, SELF, switch_two_wooden_houses_1_a_L_sprites, DiagonalSeaSlopeCheck() ) {
        1:     switch_two_wooden_houses_1_a_L_sprites_1xwater;
            switch_two_wooden_houses_1_a_L_bywater;
