                STORE_TEMP((current_year - age) < 1959 ? two_wooden_houses_1_front_old() : two_wooden_houses_1_front_new(), 19), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(Season(), 10),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_two_wooden_houses_1_b_L_nowater_snow; sprlay_two_wooden_houses_1_b_L_nowater_norm; } 

    switch (FEAT_HOUSES, SELF, switch_two_wooden_houses_1_b_L_bywater, RiverDirections() ) {
        0:     switch_two_wooden_houses_1_b_L_sprites_nowater;
        1:     switch_two_wooden_houses_1_b_L_sprites_1xwater;
        2:     switch_two_wooden_houses_1_b_L_sprites_1xwater;
        4:     switch_two_wooden_houses_1_b_L_sprites_1xwater;
        8:     switch_two_wooden_houses_1_b_L_sprites_1xwater;
            switch_two_wooden_houses_1_b_L_sprites_2xwater;
    }

    switch (FEAT_HOUSES, SELF, switch_two_wooden_houses_1_b_L_sprites, DiagonalSeaSlopeCheck() ) {
        1:     switch_two_wooden_houses_1_b_L_sprites_1xwater;
            switch_two_wooden_houses_1_b_L_bywater;
    }


// Level Selection     
// Variant Selection for ['a', 'b'] using SpriteDirectionsAB()
    
    switch (FEAT_HOUSES, SELF, switch_two_wooden_houses_1_sprites, SpriteDirectionsAB() ) {
        1: switch_two_wooden_houses_1_b_L_sprites;
           switch_two_wooden_houses_1_a_L_sprites;
    }

