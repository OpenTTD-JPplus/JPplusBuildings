// Spritelayout Switches
    // a
        // L
            switch (FEAT_HOUSES,SELF, switch_shotengai_3_a_L_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? shotengai_3_build_clr_old() : shotengai_3_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1945 ? shotengai_3_lefty_old() : shotengai_3_lefty_new(), 15), 
                STORE_TEMP((current_year - age) < 1945 ? shotengai_3_right_old() : shotengai_3_right_new(), 17), 
                STORE_TEMP((current_year - age) < 1945 ? shotengai_3_front_old() : shotengai_3_front_new(), 19), 
                STORE_TEMP(shotengai_3_signs_new(), 9), 
                STORE_TEMP(GroundAlley(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_shotengai_3_a_L_snow; sprlay_shotengai_3_a_L_norm; } 
    // b
