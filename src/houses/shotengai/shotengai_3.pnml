// Spritelayouts for shotengai_3

// A variant | L level | Norm
    spritelayout sprlay_shotengai_3_a_L_norm {
        ground {
            sprite:        spr_shotengai_3_a_ground_norm(LOAD_TEMP(2));
        }
        building {
            sprite:        spr_shotengai_3_a_L_norm (construction_state);
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(1);
        }
        childsprite { // lefty
            sprite:        spr_shotengai_3_a_lefty_norm (construction_state); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(15);
        }
        childsprite { // right
            sprite:        spr_shotengai_3_a_right_norm (construction_state); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(17);
        }
        childsprite { // front
            sprite:        spr_shotengai_3_a_front_norm (construction_state); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(19);
        }
        childsprite { // signs
            sprite:        spr_shotengai_3_a_signs (3); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(9);
            hide_sprite:  construction_state != 3;
        }
    }

