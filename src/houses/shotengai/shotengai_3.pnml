// Level Selection     
// Variant Selection for ['a', 'b', 's'] using SpriteDirectionsABS()
    
    switch (FEAT_HOUSES, SELF, switch_shotengai_3_sprites, SpriteDirectionsABS() ) {
        1: switch_shotengai_3_b_L_sprites;
        2: switch_shotengai_3_s_L_sprites;
           switch_shotengai_3_a_L_sprites;
    }

// Item Block
    item(FEAT_HOUSES, item_shotengai_3, 62, HOUSE_SIZE_1X1){
        property {
            substitute:              6;
            name:                    string(NAME_SHOTENGAI_3);
            population:              20;
            accepted_cargos:         [[PASS, 4],[MAIL, 2], [GOOD, 2]];
            local_authority_impact:  80;
            removal_cost_multiplier: 80;
            probability:             1;
            years_available:         [1900,0xFFFF];
            minimum_lifetime:        5;
            availability_mask:       [ALL_TOWNZONES, bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, ABOVE_SNOWLINE, CLIMATE_TROPIC)];
            building_class:          0;
        }
        graphics {
            default:                 switch_shotengai_3_sprites;
            construction_check:      ShotengaiOnFlat;
            cargo_production:        func_produce(3,1);
        }
    }