        spriteset (spr_osaka_m_a_fence_2x, "src/houses/osaka/gfx/fence_a_2x.png") {template_child_norm(80,1)}
        spriteset (spr_osaka_m_b_fence_1x, "src/houses/osaka/gfx/fence_b_1x.png") {template_child_norm(80,2)}
        spriteset (spr_osaka_m_b_fence_2x, "src/houses/osaka/gfx/fence_b_2x.png") {template_child_norm(80,2)}


// Spritelayouts for osaka_m

// A variant | 6L level | Norm
    spritelayout sprlay_osaka_m_a_6L_1xwater_norm {
        ground {
            sprite:        spr_osaka_m_a_ground_norm(LOAD_TEMP(2));
        }
        building {
            sprite:        spr_osaka_m_a_6L_norm (3);
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(1);
        }
        childsprite { // fence
            sprite:        spr_osaka_m_a_fence_1x (LOAD_TEMP(4)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
            always_draw:  1;
            hide_sprite:  construction_state != 3;
        }
    }

