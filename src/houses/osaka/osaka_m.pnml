// Ground

        spriteset (spr_osaka_m_a_ground_norm, "src/houses/osaka/gfx/ground_norm.png") {template_ground_norm(80,1)}
        spriteset (spr_osaka_m_a_ground_snow, "src/houses/osaka/gfx/ground_snow.png") {template_ground_norm(80,1)}
        spriteset (spr_osaka_m_b_ground_norm, "src/houses/osaka/gfx/ground_norm.png") {template_ground_norm(80,2)}
