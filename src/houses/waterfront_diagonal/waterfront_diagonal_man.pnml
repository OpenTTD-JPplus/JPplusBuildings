    // Fence Colours - Fence Colours Profiles: ['mar484Dbla0106', 'mar484Dbrn2025', 'mar484Dbrn2227', 'red_brown']
        switch (FEAT_HOUSES, SELF, waterfront_diagonal_fence_new, getbits(random_bits, 2, 2)) {
            0:  return 12;
            1:  return 84;
            2:  return 85;
                return 86;
        }


// Spritelayout Switches
    // h
        // L
            switch (FEAT_HOUSES,SELF, switch_waterfront_diagonal_waterfront, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_diagonal_house_old() : waterfront_diagonal_house_new(), 23), 
                STORE_TEMP(waterfront_diagonal_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_waterfront_diagonal_h_L_snow; sprlay_waterfront_diagonal_h_L_norm; } 

    switch (FEAT_HOUSES, SELF, switch_waterfront_diagonal_sprites, CornerSeaCheck() ){
        1:  switch_waterfront_diagonal_waterfront;
            switch_fountain_fallback_sprites;
        } 

// Item Block
    item(FEAT_HOUSES, item_waterfront_diagonal, 4, HOUSE_SIZE_1X1){
        property {
            substitute:              6;
            name:                    string(NAME_WATERFRONT_DIAGONAL);
            population:              20;
            accepted_cargos:         [[PASS, 4],[MAIL, 2]];
            local_authority_impact:  80;
            removal_cost_multiplier: 80;
            probability:             5;
            years_available:         [1870,0xFFFF];
            minimum_lifetime:        5;
            availability_mask:       [bitmask(TOWNZONE_OUTER_SUBURB , TOWNZONE_OUTSKIRT, TOWNZONE_EDGE), bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, ABOVE_SNOWLINE, CLIMATE_TROPIC)];
            building_class:          0;
        }
        graphics {
            default:                 switch_waterfront_diagonal_sprites;
            foundations:             CB_RESULT_NO_FOUNDATIONS;
            construction_check:      CornerSeaCheck();
            cargo_production:        func_produce(2,1);
        }
    }