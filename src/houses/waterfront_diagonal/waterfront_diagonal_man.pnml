// Buildings

    // L
        spriteset (spr_waterfront_diagonal_h_L_norm, "src/houses/waterfront_diagonal/gfx/earth_norm.png") {template_house_norm(80,2)}
        spriteset (spr_waterfront_diagonal_h_L_snow, "src/houses/waterfront_diagonal/gfx/earth_snow.png") {template_house_norm(80,2)}

// Found

        spriteset (spr_waterfront_diagonal_h_found, "src/houses/waterfront_diagonal/gfx/found.png") {template_child_norm(80,2)}

// House

        spriteset (spr_waterfront_diagonal_h_house_norm, "src/houses/waterfront_diagonal/gfx/house_norm.png") {template_child_norm(80,2)}
        spriteset (spr_waterfront_diagonal_h_house_snow, "src/houses/waterfront_diagonal/gfx/house_snow.png") {template_child_norm(80,2)}

// Fence

        spriteset (spr_waterfront_diagonal_h_fence, "src/houses/waterfront_diagonal/gfx/fence.png") {template_child_norm(80,2)}


// Spritelayouts for waterfront_diagonal

// H variant | L level | Norm
    spritelayout sprlay_waterfront_diagonal_h_L_norm {
        ground {
            sprite:        GROUNDSPRITE_WATER;
        }
        building {
            sprite:        spr_waterfront_diagonal_h_L_norm (LOAD_TEMP(2));
            always_draw:  1;
        }
        childsprite { // found
            sprite:        spr_waterfront_diagonal_h_found (LOAD_TEMP(2)); 
            always_draw:  1;
        }
        childsprite { // house
            sprite:        spr_waterfront_diagonal_h_house_norm (LOAD_TEMP(2)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(23);
        }
        childsprite { // fence
            sprite:        spr_waterfront_diagonal_h_fence (LOAD_TEMP(2)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
        }
    }

// H variant | L level | Snow
    spritelayout sprlay_waterfront_diagonal_h_L_snow {
        ground {
            sprite:        GROUNDSPRITE_WATER;
        }
        building {
            sprite:        spr_waterfront_diagonal_h_L_snow (LOAD_TEMP(2));
            always_draw:  1;
        }
        childsprite { // found
            sprite:        spr_waterfront_diagonal_h_found (LOAD_TEMP(2)); 
            always_draw:  1;
        }
        childsprite { // house
            sprite:        spr_waterfront_diagonal_h_house_snow (LOAD_TEMP(2)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(23);
        }
        childsprite { // fence
            sprite:        spr_waterfront_diagonal_h_fence (LOAD_TEMP(2)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
        }
    }


