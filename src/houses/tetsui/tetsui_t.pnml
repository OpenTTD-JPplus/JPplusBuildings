// Random Switches
    // Building Colours
        switch (FEAT_HOUSES, SELF, tetsui_t_build_clr_new, getbits(random_bits, 1, 4)) {
            0:  return 49;
            1:  return 58;
            2:  return 62;
            3:  return 63;
            4:  return 64;
            5:  return 65;
            6:  return 70;
            7:  return 71;
            8:  return 72;
            9:  return 73;
            10: return 74;
            11: return 75;
            12: return 80;
            13: return 81;
            14: return 83;
                return 86;
        }
    // Fence Colours - Fence Colours Profiles: ['mar484Dbla0106', 'mar484Dbrn2025', 'mar484Dbrn2227', 'red_brown']
        switch (FEAT_HOUSES, SELF, tetsui_t_fence_new, getbits(random_bits, 2, 2)) {
            0:  return 12;
            1:  return 84;
            2:  return 85;
                return 86;
        }


// Spritelayout Switches
    // a
        // 4L
            switch (FEAT_HOUSES,SELF, switch_tetsui_t_a_4L_sprites_1xwater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(tetsui_t_fence_new(), 5), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(GroundSlopes(), 4),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_a_4L_1xwater_snow; sprlay_tetsui_t_a_4L_1xwater_norm; } 

            switch (FEAT_HOUSES,SELF, switch_tetsui_t_a_4L_sprites_2xwater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(tetsui_t_fence_new(), 5), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(GroundSlopes(), 4),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_a_4L_2xwater_snow; sprlay_tetsui_t_a_4L_2xwater_norm; } 

            switch (FEAT_HOUSES,SELF, switch_tetsui_t_a_4L_sprites_nowater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(GroundAlley(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_a_4L_nowater_snow; sprlay_tetsui_t_a_4L_nowater_norm; } 

    switch (FEAT_HOUSES, SELF, switch_tetsui_t_a_4L_bywater, RiverDirections() ) {
        0:     switch_tetsui_t_a_4L_sprites_nowater;
        1:     switch_tetsui_t_a_4L_sprites_1xwater;
        2:     switch_tetsui_t_a_4L_sprites_1xwater;
        4:     switch_tetsui_t_a_4L_sprites_1xwater;
        8:     switch_tetsui_t_a_4L_sprites_1xwater;
            switch_tetsui_t_a_4L_sprites_2xwater;
    }

    switch (FEAT_HOUSES, SELF, switch_tetsui_t_a_4L_sprites, DiagonalSeaSlopeCheck() ) {
        1:     switch_tetsui_t_a_4L_sprites_1xwater;
            switch_tetsui_t_a_4L_bywater;
    }
    // b
        // 4L
            switch (FEAT_HOUSES,SELF, switch_tetsui_t_b_4L_sprites_1xwater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(tetsui_t_fence_new(), 5), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(GroundSlopes(), 4),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_b_4L_1xwater_snow; sprlay_tetsui_t_b_4L_1xwater_norm; } 

            switch (FEAT_HOUSES,SELF, switch_tetsui_t_b_4L_sprites_2xwater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(tetsui_t_fence_new(), 5), 
                STORE_TEMP(GroundAlley(), 2), 
                STORE_TEMP(GroundSlopes(), 4),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_b_4L_2xwater_snow; sprlay_tetsui_t_b_4L_2xwater_norm; } 

            switch (FEAT_HOUSES,SELF, switch_tetsui_t_b_4L_sprites_nowater, [ 
                STORE_TEMP(tetsui_t_build_clr_new(), 1), 
                STORE_TEMP(GroundAlley(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_tetsui_t_b_4L_nowater_snow; sprlay_tetsui_t_b_4L_nowater_norm; } 

    switch (FEAT_HOUSES, SELF, switch_tetsui_t_b_4L_bywater, RiverDirections() ) {
        0:     switch_tetsui_t_b_4L_sprites_nowater;
        1:     switch_tetsui_t_b_4L_sprites_1xwater;
        2:     switch_tetsui_t_b_4L_sprites_1xwater;
        4:     switch_tetsui_t_b_4L_sprites_1xwater;
        8:     switch_tetsui_t_b_4L_sprites_1xwater;
            switch_tetsui_t_b_4L_sprites_2xwater;
    }

    switch (FEAT_HOUSES, SELF, switch_tetsui_t_b_4L_sprites, DiagonalSeaSlopeCheck() ) {
        1:     switch_tetsui_t_b_4L_sprites_1xwater;
            switch_tetsui_t_b_4L_bywater;
    }


// Level Selection     
// Variant Selection for ['a', 'b'] using SpriteDirectionsAB()
    
    switch (FEAT_HOUSES, SELF, switch_tetsui_t_sprites, SpriteDirectionsAB() ) {
        1: switch_tetsui_t_b_4L_sprites;
           switch_tetsui_t_a_4L_sprites;
    }

// Item Block
    item(FEAT_HOUSES, item_tetsui_t, 143, HOUSE_SIZE_1X1){
        property {
            substitute:              27;
            name:                    string(NAME_TETSUI_T);
            population:              75;
            accepted_cargos:         [[PASS, 4],[MAIL, 2]];
            local_authority_impact:  80;
            removal_cost_multiplier: 80;
            probability:             1;
            years_available:         [1955,0xFFFF];
            minimum_lifetime:        5;
            availability_mask:       [ALL_TOWNZONES & ~bitmask(TOWNZONE_EDGE), bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, ABOVE_SNOWLINE, CLIMATE_TROPIC)];
            building_class:          24;
        }
        graphics {
            default:                 switch_tetsui_t_sprites;
            construction_check:      switch_tiny_con_check;
            cargo_production:        func_produce(6,2);
        }
    }