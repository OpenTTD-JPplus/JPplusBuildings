// Spritelayouts for tetsui_t

// A variant | 4L level | Norm
    spritelayout sprlay_tetsui_t_a_4L_1xwater_norm {
        ground {
            sprite:        spr_tetsui_t_a_ground_norm(LOAD_TEMP(2));
        }
        building {
            sprite:        spr_tetsui_t_a_4L_norm (3);
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(1);
        }
        childsprite { // fence
            sprite:        spr_tetsui_t_a_fence_1x (LOAD_TEMP(4)); 
            recolour_mode: RECOLOUR_REMAP;
            palette:       recolour_remap + LOAD_TEMP(5);
            always_draw:  1;
            hide_sprite:  construction_state != 3;
        }
    }

