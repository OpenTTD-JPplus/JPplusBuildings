            switch (FEAT_HOUSES,SELF, switch_waterfront_house_h_L_light_onedown_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_build_clr_old() : waterfront_house_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_fence_old() : waterfront_house_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_waterfront_house_h_L_onedown_snow; sprlay_waterfront_house_h_L_onedown_light_norm; } 

            switch (FEAT_HOUSES,SELF, switch_waterfront_house_h_L_dark_diagonal_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_build_clr_old() : waterfront_house_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_fence_old() : waterfront_house_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_waterfront_house_h_L_diagonal_snow; sprlay_waterfront_house_h_L_diagonal_dark_norm; } 

            switch (FEAT_HOUSES,SELF, switch_waterfront_house_h_L_dark_oneup_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_build_clr_old() : waterfront_house_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_fence_old() : waterfront_house_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_waterfront_house_h_L_oneup_snow; sprlay_waterfront_house_h_L_oneup_dark_norm; } 

            switch (FEAT_HOUSES,SELF, switch_waterfront_house_h_L_dark_valley_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_build_clr_old() : waterfront_house_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_fence_old() : waterfront_house_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
