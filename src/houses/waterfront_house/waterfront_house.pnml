                {1: sprlay_waterfront_house_h_L_valley_snow; sprlay_waterfront_house_h_L_valley_dark_norm; } 

            switch (FEAT_HOUSES,SELF, switch_waterfront_house_h_L_dark_onedown_sprites, [ 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_build_clr_old() : waterfront_house_build_clr_new(),1), 
                STORE_TEMP((current_year - age) < 1959 ? waterfront_house_fence_old() : waterfront_house_fence_new(), 5), 
                STORE_TEMP(GroundSlopes(), 2),
                terrain_type == TILETYPE_SNOW])
                {1: sprlay_waterfront_house_h_L_onedown_snow; sprlay_waterfront_house_h_L_onedown_dark_norm; } 

    // Which sprite quartet to use based on slope - light
    switch (FEAT_HOUSES,SELF,switch_waterfront_house_h_L_light_sprites, nearby_tile_slope(0,0)  ) {
        SLOPE_W:   switch_waterfront_house_h_L_light_oneup_sprites;
        SLOPE_S:   switch_waterfront_house_h_L_light_oneup_sprites;
        SLOPE_E:   switch_waterfront_house_h_L_light_oneup_sprites;
        SLOPE_N:   switch_waterfront_house_h_L_light_oneup_sprites;
        SLOPE_SW:  switch_waterfront_house_h_L_light_diagonal_sprites;
        SLOPE_SE:  switch_waterfront_house_h_L_light_diagonal_sprites;
        SLOPE_NW:  switch_waterfront_house_h_L_light_diagonal_sprites;
        SLOPE_NE:  switch_waterfront_house_h_L_light_diagonal_sprites;
        SLOPE_EW:  switch_waterfront_house_h_L_light_valley_sprites;
        SLOPE_NS:  switch_waterfront_house_h_L_light_valley_sprites;
        SLOPE_NWS: switch_waterfront_house_h_L_light_onedown_sprites;
        SLOPE_WSE: switch_waterfront_house_h_L_light_onedown_sprites;
        SLOPE_SEN: switch_waterfront_house_h_L_light_onedown_sprites;
        SLOPE_ENW: switch_waterfront_house_h_L_light_onedown_sprites;
        SLOPE_FLAT:switch_waterfront_house_h_L_light_valley_sprites;
        switch_waterfront_house_h_L_light_diagonal_sprites;
    }

    // Which sprite quartet to use based on slope - dark
    switch (FEAT_HOUSES,SELF,switch_waterfront_house_h_L_dark_sprites, nearby_tile_slope(0,0)  ) {
        SLOPE_W:   switch_waterfront_house_h_L_dark_oneup_sprites;
        SLOPE_S:   switch_waterfront_house_h_L_dark_oneup_sprites;
        SLOPE_E:   switch_waterfront_house_h_L_dark_oneup_sprites;
        SLOPE_N:   switch_waterfront_house_h_L_dark_oneup_sprites;
        SLOPE_SW:  switch_waterfront_house_h_L_dark_diagonal_sprites;
        SLOPE_SE:  switch_waterfront_house_h_L_dark_diagonal_sprites;
        SLOPE_NW:  switch_waterfront_house_h_L_dark_diagonal_sprites;
        SLOPE_NE:  switch_waterfront_house_h_L_dark_diagonal_sprites;
        SLOPE_EW:  switch_waterfront_house_h_L_dark_valley_sprites;
        SLOPE_NS:  switch_waterfront_house_h_L_dark_valley_sprites;
        SLOPE_NWS: switch_waterfront_house_h_L_dark_onedown_sprites;
        SLOPE_WSE: switch_waterfront_house_h_L_dark_onedown_sprites;
        SLOPE_SEN: switch_waterfront_house_h_L_dark_onedown_sprites;
        SLOPE_ENW: switch_waterfront_house_h_L_dark_onedown_sprites;
        SLOPE_FLAT:switch_waterfront_house_h_L_dark_valley_sprites;
        switch_waterfront_house_h_L_dark_diagonal_sprites;
    }

    // Which ground tile to use
    switch (FEAT_HOUSES,SELF,switch_waterfront_house_sprites, GroundSlopesGround()  ) {
        0:  switch_waterfront_house_h_L_light_sprites;
            switch_waterfront_house_h_L_dark_sprites;
    }


// Item Block
    item(FEAT_HOUSES, item_waterfront_house, 21, HOUSE_SIZE_1X1){
        property {
            substitute:              6;
            name:                    string(NAME_WATERFRONT_HOUSE);
            population:              20;
            accepted_cargos:         [[PASS, 4],[MAIL, 2]];
            local_authority_impact:  80;
            removal_cost_multiplier: 80;
            probability:             5;
            years_available:         [1870,0xFFFF];
            minimum_lifetime:        5;
            availability_mask:       [bitmask(TOWNZONE_OUTER_SUBURB , TOWNZONE_OUTSKIRT, TOWNZONE_EDGE), bitmask(CLIMATE_TEMPERATE, CLIMATE_ARCTIC, ABOVE_SNOWLINE, CLIMATE_TROPIC)];
            building_class:          0;
        }
        graphics {
            default:                 switch_waterfront_house_sprites;
            construction_check:      switch_waterfront_con_check;
            cargo_production:        func_produce(2,1);
        }
    }