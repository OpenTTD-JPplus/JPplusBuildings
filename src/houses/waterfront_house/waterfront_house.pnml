// Random Switches
    // Building Colours
        switch (FEAT_HOUSES, SELF, waterfront_house_build_clr_new, getbits(random_bits, 1, 3)) {
            0:  return 31;
            1:  return 53;
            2:  return 60;
            3:  return 61;
            4:  return 62;
            5:  return 70;
            6:  return 78;
                return 84;
        }
        switch (FEAT_HOUSES, SELF, waterfront_house_build_clr_old, getbits(random_bits, 1, 3)) {
            0:  return 15;
            1:  return 16;
            2:  return 22;
            3:  return 23;
            4:  return 25;
            5:  return 62;
            6:  return 92;
                return 93;
        }
    // Fence Colours - Fence Colours Profiles: ['mar484Dbla0106', 'mar484Dbrn2025', 'mar484Dbrn2227', 'red_brown']
        switch (FEAT_HOUSES, SELF, waterfront_house_fence_new, getbits(random_bits, 2, 2)) {
            0:  return 12;
            1:  return 84;
            2:  return 85;
                return 86;
        }
        switch (FEAT_HOUSES, SELF, waterfront_house_fence_old, getbits(random_bits, 2, 2)) {
